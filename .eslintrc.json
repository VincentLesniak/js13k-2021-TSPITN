{
  // utilise le guide de style imposé par le sujet
  "extends": ["google"],
  // autorise les fonctions du navigateur et de node
  "env": {
    "browser": true,
    "node": true,
    "es2021": true
  },
  // définit la lecture du code en version moderne
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  // règles personnalisées
  "rules": {
    // tolère l'utilisation de l'ancien mot-clé var
    "no-var": "off",
    // accepte les noms qui ne respectent pas le format camelcase
    "camelcase": "off"
  }
}